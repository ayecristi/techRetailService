extends ../layout

block content
  h2 Nueva Tienda

  form(method="POST" action="/tiendas/guardar")
    p
      label(for="nombre") Nombre:
      br
      input(type="text" id="nombre" name="nombre" required)

    p
      label(for="categoria") Categoría:
      br
      input(type="text" id="categoria" name="categoria")

    p
      label(for="email") Email:
      br
      input(type="email" id="email" name="email")



    p
      label(for="activo")
        input(type="checkbox" id="activo" name="activo" checked)
        |  Activa

    p
      button(type="submit" class="btn" style="width: 150px; padding: 8px 16px;") Guardar
      |  
      button(type="button" class="btn" style="width: 150px; padding: 8px 16px; cursor: pointer;" onclick="window.location.href='/tiendas'") Cancelar
