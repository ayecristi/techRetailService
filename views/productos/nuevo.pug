extends ../layout

block content
  .login-card(style="max-width: 500px; margin: 40px auto;")
    h2 Nuevo Producto
    p.subtitle Agregá un producto a tu catálogo de ventas.

    form(method="POST" action="/productos/guardar")
      .form-group
        label(for="nombre") Nombre
        input(type="text" id="nombre" name="nombre" placeholder="Ej: Remera básica" required style="width: 100%;")

      .form-group
        label(for="descripcion") Descripción
        input(type="text" id="descripcion" name="descripcion" placeholder="Descripción del producto" style="width: 100%;")

      .form-row
        .form-group(style="flex: 1;")
          label(for="precio") Precio ($)
          input(type="number" id="precio" name="precio" step="0.01" placeholder="0.00" min="0" required style="width: 100%;")
        
        .form-group(style="flex: 1;")
          label(for="stock") Stock
          input(type="number" id="stock" name="stock" placeholder="0" min="0" required style="width: 100%;")

      .form-group
        label(for="categoria") Categoría
        input(type="text" id="categoria" name="categoria" placeholder="Ej: Ropa, Electrónica..." style="width: 100%;")

      .form-group
        label(for="imagenUrl") URL de Imagen
        input(type="text" id="imagenUrl" name="imagenUrl" placeholder="http://..." style="width: 100%;")

      .btn-row(style="margin-top: 25px; display: flex; gap: 12px;")
        button.btn-primary(type="submit" style="flex: 1; padding: 12px; text-align: center; border: none; cursor: pointer;") Guardar Producto
        a.btn-outline(href="/productos/listar" style="flex: 1; padding: 12px; text-align: center; text-decoration: none; border-radius: 6px; box-sizing: border-box;") Cancelar