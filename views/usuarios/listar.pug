extends ../layout

block content
  .dashboard-wrapper
    .dashboard-header
      div
        h2 Control de Usuarios
        p Gestión de accesos y personal asociado a tu tienda.
      a.btn-primary(href="/usuarios/nuevo") + Nuevo Usuario

    if usuarios && usuarios.length > 0
      table
        thead
          tr
            th Nombre Completo
            th Email Login
            th Rol
            th Estado
            th Último Acceso
            th.text-right Acciones

        tbody
          each usuario in usuarios
            tr
              td
                span(style="color: var(--primary); font-weight: 600;")= usuario.personaId ? (usuario.personaId.nombre + ' ' + usuario.personaId.apellido) : 'N/A'
              td= usuario.email
              td
                span(style="text-transform: capitalize;")= usuario.rol
              td
                - var estado = usuario.activo
                if estado === 'activo'
                  span(style="background-color: #10b98120; color: #34d399; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px; border: 1px solid #10b98130; text-transform: uppercase;") Activo
                else if estado === 'suspendido'
                  span(style="background-color: #f59e0b20; color: #fbbf24; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px; border: 1px solid #f59e0b30; text-transform: uppercase;") Suspendido
                else if estado === 'eliminado'
                  span(style="background-color: #ef444420; color: #f87171; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px; border: 1px solid #ef444430; text-transform: uppercase;") Eliminado
                else
                  span(style="color: var(--text-muted);")= estado
              td
                if usuario.fechaUltimoAcceso
                  span= new Date(usuario.fechaUltimoAcceso).toLocaleString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })
                else
                  span(style="color: var(--text-muted); font-style: italic;") Nunca accedió
              td(style="text-align: right;")
                .btn-row(style="display: inline-flex; gap: 8px; justify-content: flex-end;")
                  a.btn-outline(href=`/usuarios/editar/${usuario._id}` style="padding: 6px 12px; font-size: 12px; border-color: #f59e0b40; color: #f59e0b;") Editar
                  form(method="POST" action=`/usuarios/eliminar/${usuario._id}` style="display:inline;" onsubmit="return confirm('¿Está seguro de eliminar este usuario?')")
                    button.btn-outline(type="submit" style="padding: 6px 12px; font-size: 12px; border-color: #ef444440; color: #ef4444; background: transparent; cursor: pointer;") Eliminar
    else
      .empty-state
        span 👥
        h4 Sin usuarios registrados
        p Registra vendedores o administradores adicionales para tu tienda.
        a.btn-outline(href="/usuarios/nuevo") Crear el primer usuario
