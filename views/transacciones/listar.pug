extends ../layout

block content
  h2 Lista de transacciones

  p
    <!-- boton exclusivo para pruebas -->
    a.btn(href="/transacciones/crear") Nueva transacción 

  if transacciones && transacciones.length > 0
    table(border="1")
      tr
        th ID
        th Tienda ID
        th Usuario ID
        th Fecha
        th Monto
        th Método de Pago
        th Estado
        th Referencia
        th Acciones

      each transaccion in transacciones
        tr
          td= transaccion.id
          td= transaccion.tiendaId
          td= transaccion.usuarioId
          td= new Date(transaccion.creadoEn).toLocaleDateString('es-AR')
          td $#{transaccion.monto.toFixed(2)}
          td= transaccion.metodoPago
          td= transaccion.estado
          td= transaccion.referencia
          td
            a.btn(href=`/transacciones/ver/${transaccion.id}`) Ver
            |  
            a.btn(href=`/transacciones/editar/${transaccion.id}`) Editar
            |  
            form(method="POST" action=`/transacciones/eliminar/${transaccion.id}` style="display:inline" onsubmit="return confirm('¿Está seguro de eliminar esta transacción?')")
              button.btn(type="submit" style="background-color: #ff4444; color: white;") Eliminar
  else
    p No hay transacciones registradas.
    p
      a.btn(href="/transacciones/crear") Crear la primera transacción
