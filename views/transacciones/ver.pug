extends ../layout

block content
  .dashboard-wrapper(style="max-width: 850px; margin: 45px auto;")
    if error
      .card.card-amber(style="padding: 40px; text-align: center; border-left-color: #ef4444; margin-top: 20px;")
        span(style="font-size: 48px; display: block; margin-bottom: 15px;") ⚠️
        h3(style="margin-top: 0; color: #ef4444; font-size: 24px; font-weight: 600;") Acceso Restringido o Error
        p(style="color: var(--text-muted); margin-bottom: 25px; font-size: 15px; max-width: 500px; margin-left: auto; margin-right: auto; line-height: 1.5;") #{error}
        a.btn-outline(href="/transacciones/listar" style="display: inline-block; padding: 12px 24px;") Volver al Listado
    else
      .dashboard-header(style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 15px;")
        div
          h2(style="display: flex; align-items: center; gap: 12px; margin: 0; font-size: 28px; font-weight: 600; flex-wrap: wrap;") 
            span Detalle de Transacción
            - var est = transaccion.estado.toLowerCase()
            if est === 'completado'
              span(style="background-color: #10b98120; color: #34d399; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 12px; border: 1px solid #10b98130; text-transform: uppercase; letter-spacing: 0.5px;") Completado
            else if est === 'pendiente'
              span(style="background-color: #f59e0b20; color: #fbbf24; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 12px; border: 1px solid #f59e0b30; text-transform: uppercase; letter-spacing: 0.5px;") Pendiente
            else if est === 'cancelado'
              span(style="background-color: #ef444420; color: #f87171; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 12px; border: 1px solid #ef444430; text-transform: uppercase; letter-spacing: 0.5px;") Cancelado
            else if est === 'reembolsado'
              span(style="background-color: #6b728020; color: #9ca3af; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 12px; border: 1px solid #6b728030; text-transform: uppercase; letter-spacing: 0.5px;") Reembolsado
            else
              span(style="background-color: #4b556320; color: #d1d5db; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 12px; border: 1px solid #4b556330; text-transform: uppercase; letter-spacing: 0.5px;")= transaccion.estado
          p(style="margin: 8px 0 0 0; font-size: 14px; color: var(--text-muted);") 
            | ID de Registro: 
            span(style="color: var(--primary); font-weight: 600;")= transaccion.id.toUpperCase()

      // Grid de Resumen Financiero
      .dashboard-grid(style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 10px;")
        .card.card-green(style="border-left-color: #10b981; padding: 20px;")
          p(style="font-size: 12px; margin-bottom: 6px; font-weight: 600; color: var(--text-muted); text-transform: uppercase;") Monto Total
          h3(style="font-size: 26px; color: #f8fafc; margin: 0; font-weight: 700;") $#{transaccion.monto.toFixed(2)}
        .card(style="border-left-color: var(--primary); padding: 20px;")
          p(style="font-size: 12px; margin-bottom: 6px; font-weight: 600; color: var(--text-muted); text-transform: uppercase;") Comisión (Sistema)
          h3(style="font-size: 26px; color: #f8fafc; margin: 0; font-weight: 700;") $#{transaccion.comision.toFixed(2)}
        .card.card-amber(style="border-left-color: #fbbf24; padding: 20px;")
          p(style="font-size: 12px; margin-bottom: 6px; font-weight: 600; color: var(--text-muted); text-transform: uppercase;") Método de Pago
          h3(style="font-size: 20px; color: #fbbf24; text-transform: capitalize; margin: 6px 0 0 0; font-weight: 700;")= transaccion.metodoPago

      // Información General
      .card(style="border-left: none; background-color: var(--bg-card); padding: 25px; border-radius: 12px; border: 1px solid var(--border-color); margin-top: 20px;")
        h4(style="margin-top: 0; margin-bottom: 20px; font-size: 16px; font-weight: 600; padding-bottom: 10px; border-bottom: 1px solid var(--border-color); color: #f8fafc;") Datos Generales del Movimiento
        
        .form-row(style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;")
          div(style="display: flex; flex-direction: column; gap: 15px;")
            div
              strong(style="color: var(--text-muted); font-size: 11px; text-transform: uppercase; display: block; letter-spacing: 0.5px; margin-bottom: 4px;") Tienda
              p(style="margin: 0; font-size: 15px; font-weight: 500; color: #f8fafc;")= transaccion.tiendaId.nombre || "N/A"
            div
              strong(style="color: var(--text-muted); font-size: 11px; text-transform: uppercase; display: block; letter-spacing: 0.5px; margin-bottom: 4px;") Cliente / Comprador
              p(style="margin: 0; font-size: 15px; font-weight: 500; color: #f8fafc;")
                if usuario
                  | #{usuario.nombre} 
                  span(style="color: var(--text-muted); font-size: 13px; font-weight: normal;") (ID: #{transaccion.usuarioId})
                else
                  | Usuario ID: #{transaccion.usuarioId}
            div
              strong(style="color: var(--text-muted); font-size: 11px; text-transform: uppercase; display: block; letter-spacing: 0.5px; margin-bottom: 6px;") Referencia
              p(style="margin: 0;")
                if transaccion.referencia
                  span(style="background-color: #3b82f620; color: #60a5fa; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 600; border: 1px solid #3b82f630;")= transaccion.referencia
                else
                  span(style="color: var(--text-muted); font-size: 14px; font-style: italic;") Sin referencia registrada
          
          div(style="display: flex; flex-direction: column; gap: 15px;")
            div
              strong(style="color: var(--text-muted); font-size: 11px; text-transform: uppercase; display: block; letter-spacing: 0.5px; margin-bottom: 4px;") Fecha y Hora de Operación
              p(style="margin: 0; font-size: 14px; color: #f8fafc;")= new Date(transaccion.creadoEn || transaccion.createdAt).toLocaleString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })
            if transaccion.descripcion
              div
                strong(style="color: var(--text-muted); font-size: 11px; text-transform: uppercase; display: block; letter-spacing: 0.5px; margin-bottom: 4px;") Descripción / Notas
                p(style="margin: 0; font-size: 14px; color: var(--text-muted); line-height: 1.5; background-color: #171717; padding: 12px; border-radius: 6px; border: 1px solid var(--border-color);")= transaccion.descripcion

      // Tabla de items
      if transaccion.items && transaccion.items.length > 0
        div(style="margin-top: 25px;")
          h4(style="margin-top: 0; margin-bottom: 12px; font-size: 16px; font-weight: 600; color: #f8fafc;") Ítems de la Compra
          table
            thead
              tr
                th Producto
                th(style="width: 80px; text-align: center;") Cant.
                th(style="width: 140px; text-align: right;") Precio Unitario
                th(style="width: 140px; text-align: right;") Subtotal
            tbody
              each item in transaccion.items
                tr
                  td(style="font-weight: 500; color: #f8fafc;")= item.nombre
                  td(style="text-align: center;")= item.cantidad
                  td(style="text-align: right; color: var(--text-muted);") $#{item.precioUnitario.toFixed(2)}
                  td(style="text-align: right; font-weight: 600; color: #f8fafc;") $#{item.subtotal.toFixed(2)}

      // Acciones
      .btn-row(style="margin-top: 35px; display: flex; gap: 15px; align-items: center; flex-wrap: wrap;")
        a.btn-outline(href="/transacciones/listar" style="flex: 1; min-width: 160px; text-align: center; text-decoration: none;")
          | ⬅️ Volver al Listado

        if transaccion.estado === 'pendiente'
          form(method="POST" action=`/transacciones/procesar/${transaccion.id}` style="flex: 1; min-width: 160px; display: flex;" onsubmit="return confirm('¿Procesar esta venta como completada?')")
            button.btn-outline(type="submit" style="width: 100%; text-align: center; border-color: #10b98140; color: #34d399; background: transparent; cursor: pointer; padding: 12px; font-weight: 600; font-size: 14px; border-radius: 6px;")
              | ✅ Procesar Venta

        if transaccion.estado === 'completado'
          form(method="POST" action=`/transacciones/reembolsar/${transaccion.id}` style="flex: 1; min-width: 160px; display: flex;" onsubmit="return confirm('¿Confirmar reembolso de esta transacción?')")
            button.btn-outline(type="submit" style="width: 100%; text-align: center; border-color: #6b728040; color: #9ca3af; background: transparent; cursor: pointer; padding: 12px; font-weight: 600; font-size: 14px; border-radius: 6px;")
              | 🔄 Reembolsar

