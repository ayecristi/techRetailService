extends ../layout

block content
  h2 Nueva transacción

  form(method="POST" action="/transacciones/guardar")
    p
      label(for="usuarioId") Usuario:
      br
      select(id="usuarioId" name="usuarioId" required)
        option(value="") -- Seleccionar Usuario --
        each usuario in usuarios
          option(value=usuario.id)= usuario.nombre

    p
      label(for="tiendaId") Tienda:
      br
      select(id="tiendaId" name="tiendaId" required)
        option(value="") -- Seleccionar Tienda --
        each tienda in tiendas
          option(value=tienda._id)= tienda.nombre

    p
      label(for="monto") Monto ($):
      br
      input(type="number" id="monto" name="monto" step="0.01" required)

    p
      label(for="metodoPago") Método de Pago:
      br
      select(id="metodoPago" name="metodoPago" required)
        option(value="") -- Seleccionar --
        option(value="tarjeta") Tarjeta de Crédito/Débito
        option(value="transferencia") Transferencia Bancaria
        option(value="efectivo") Efectivo
        option(value="paypal") PayPal
        option(value="criptomoneda") Criptomoneda

    p
      label(for="descripcion") Descripción:
      br
      textarea(id="descripcion" name="descripcion" rows="3" style="width: 100%")

    p
      label(for="referencia") Referencia/Factura:
      br
      input(type="text" id="referencia" name="referencia")

    p
      button(type="submit" class="btn" style="width: 150px; padding: 8px 16px;") Guardar
      |  
      button(type="button" class="btn" style="width: 150px; padding: 8px 16px; cursor: pointer;" onclick="window.location.href='/transacciones/listar'") Cancelar
