# Configuración del servidor
PORT=3000
NODE_ENV=development

# Base de datos MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_db>?retryWrites=true&w=majority

# Configuración de la aplicación
APP_NAME=TechRetail Service
APP_VERSION=1.0.0

# Logs
LOG_LEVEL=info

# Clave secreta para sesiones
SESSION_SECRET=reemplazar_con_clave_aleatoria_segura

# Clave secreta para JWT
JWT_SECRET=reemplazar_con_clave_aleatoria_segura
